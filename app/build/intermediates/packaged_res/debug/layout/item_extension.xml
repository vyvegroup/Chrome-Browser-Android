<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:background="?attr/selectableItemBackground">

    <!-- Extension Icon -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/iconContainer"
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#E8F0FE">

        <ImageView
            android:id="@+id/extensionIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_extensions"
            app:tint="#4285F4" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Extension Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/extensionName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Extension Name"
            android:textColor="#202124"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/extensionDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Extension description"
            android:textColor="#5F6368"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Extension Source Badge -->
        <TextView
            android:id="@+id/extensionSource"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Chrome Store"
            android:textColor="#4285F4"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/tab_count_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

    </LinearLayout>

    <!-- Enable Switch -->
    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/extensionSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp" />

    <!-- Settings Button -->
    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:background="@drawable/ripple_oval"
        android:src="@drawable/ic_settings"
        android:visibility="gone"
        app:tint="#5F6368" />

</LinearLayout>
