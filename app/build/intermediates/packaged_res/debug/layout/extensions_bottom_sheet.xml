<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_bg">

    <!-- Drag Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="5dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/drag_handle_bg" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E8EAED"
            app:cardBackgroundColor="#FFFFFF">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_extensions"
                app:tint="#FB8C00" />

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Extensions"
                android:textColor="#202124"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add powerful features to your browser"
                android:textColor="#5F6368"
                android:textSize="12sp" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/ripple_oval"
            android:src="@drawable/ic_close"
            app:tint="#5F6368" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="#E8EAED" />

    <!-- Add Extension Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddFromStore"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Store"
            android:textSize="13sp"
            app:icon="@drawable/ic_grid"
            app:iconSize="18dp"
            app:cornerRadius="24dp"
            app:strokeColor="#DADCE0"
            android:textColor="#1A73E8"
            app:iconTint="#1A73E8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddFromZip"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="ZIP"
            android:textSize="13sp"
            app:icon="@drawable/ic_download"
            app:iconSize="18dp"
            app:cornerRadius="24dp"
            app:strokeColor="#DADCE0"
            android:textColor="#34A853"
            app:iconTint="#34A853" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddUserScript"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Script"
            android:textSize="13sp"
            app:icon="@drawable/ic_extensions"
            app:iconSize="18dp"
            app:cornerRadius="24dp"
            app:strokeColor="#DADCE0"
            android:textColor="#FB8C00"
            app:iconTint="#FB8C00" />

    </LinearLayout>

    <!-- Installed Section Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:text="Installed"
        android:textColor="#1A73E8"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.08" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/extensionsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:paddingBottom="24dp" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyExtensions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="48dp"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="88dp"
            android:layout_height="88dp"
            app:cardCornerRadius="44dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F1F3F4">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_extensions"
                app:tint="#9AA0A6" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="No extensions yet"
            android:textColor="#202124"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Add extensions from Chrome Web Store,\nZIP file, or UserScript"
            android:textColor="#5F6368"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

</LinearLayout>
