<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fitsSystemWindows="true">

    <!-- Fullscreen Container for Video -->
    <FrameLayout
        android:id="@+id/fullscreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#000000" />

    <!-- Main Content with SwipeRefresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="100dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- WebView Container -->
            <FrameLayout
                android:id="@+id/webViewContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#E8F0FE">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_home_chrome"
                        app:tint="#4285F4" />

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Start browsing"
                    android:textColor="#202124"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Enter a URL or search above"
                    android:textColor="#5F6368"
                    android:textSize="14sp" />

            </LinearLayout>

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Page Header (shows when scrolling down) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/pageHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp">

            <ImageView
                android:id="@+id/headerSecurityIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_lock"
                app:tint="#34A853" />

            <TextView
                android:id="@+id/headerTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Page Title"
                android:textColor="#202124"
                android:textSize="15sp"
                android:ellipsize="end"
                android:maxLines="1" />

            <ImageButton
                android:id="@+id/btnShowUrl"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ripple_oval"
                android:src="@drawable/ic_search"
                app:tint="#5F6368" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Floating Bottom Bar - Higher position, Better Shadow -->
    <LinearLayout
        android:id="@+id/floatingBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:layout_marginBottom="24dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="#00000000">

        <!-- Material Progress Indicator -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:visibility="gone"
            app:indicatorColor="#4285F4"
            app:trackColor="#E8EAED"
            app:trackCornerRadius="4dp"
            app:trackThickness="4dp"
            app:showAnimationBehavior="inward"
            app:hideAnimationBehavior="outward" />

        <!-- Floating URL Card with Better Shadow -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/floatingUrlCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="28dp"
            app:cardElevation="12dp"
            app:cardMaxElevation="16dp"
            app:strokeWidth="0dp"
            app:rippleColor="#1F4285F4"
            app:cardPreventCornerOverlap="true"
            app:cardUseCompatPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- URL Input Row (Compact) -->
                <LinearLayout
                    android:id="@+id/urlRow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <!-- Security Icon (Circular) -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="4dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#E6F4EA">

                        <ImageView
                            android:id="@+id/securityIcon"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_lock"
                            app:tint="#34A853" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- URL Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/urlBarLayout"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:boxBackgroundMode="none"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/urlBar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:hint="Search or URL"
                            android:imeOptions="actionGo"
                            android:inputType="textUri"
                            android:maxLines="1"
                            android:textColor="#202124"
                            android:textColorHint="#9AA0A6"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Tab Count (Rounded Square) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tabCountContainer"
                        android:layout_width="38dp"
                        android:layout_height="32dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#E8F0FE"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tabCountText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="1"
                            android:textColor="#1A73E8"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Menu Button (Circular) -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="4dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F1F3F4">

                        <ImageButton
                            android:id="@+id/btnMenu"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:background="@null"
                            android:src="@drawable/ic_more"
                            android:contentDescription="Menu"
                            app:tint="#5F6368" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Navigation Row (Expandable) -->
                <LinearLayout
                    android:id="@+id/navigationRow"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="#F8F9FA"
                    android:visibility="gone"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <!-- Back Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_margin="2dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">

                        <ImageButton
                            android:id="@+id/btnBack"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:src="@drawable/ic_back"
                            android:contentDescription="Back"
                            app:tint="#5F6368" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Forward Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_margin="2dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">

                        <ImageButton
                            android:id="@+id/btnForward"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:src="@drawable/ic_forward"
                            android:contentDescription="Forward"
                            app:tint="#5F6368" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Refresh Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_margin="2dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">

                        <ImageButton
                            android:id="@+id/btnRefresh"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:src="@drawable/ic_refresh"
                            android:contentDescription="Refresh"
                            app:tint="#5F6368" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Home Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_margin="2dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">

                        <ImageButton
                            android:id="@+id/btnHome"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:src="@drawable/ic_home_chrome"
                            android:contentDescription="Home"
                            app:tint="#5F6368" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Tabs Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_margin="2dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">

                        <ImageButton
                            android:id="@+id/btnTabs"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:src="@drawable/ic_grid"
                            android:contentDescription="Tabs"
                            app:tint="#5F6368" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
