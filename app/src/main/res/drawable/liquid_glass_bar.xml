<?xml version="1.0" encoding="utf-8"?>
<!-- iOS 26/28 Liquid Glass Floating Bar -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glass base with high transparency -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CCFFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Specular highlight -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#55FFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear"
                android:centerY="0.3" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Edge lighting -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="0.5dp" android:color="#80FFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</layer-list>
