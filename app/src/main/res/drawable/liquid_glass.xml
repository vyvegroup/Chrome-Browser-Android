<?xml version="1.0" encoding="utf-8"?>
<!-- iOS 26/28 Liquid Glass Background -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Frosted glass base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#B3FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Top highlight for depth -->
    <item android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#33FFFFFF"
                android:centerColor="#00FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Inner glow -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#40FFFFFF" />
            <corners android:radius="23dp" />
        </shape>
    </item>
</layer-list>
