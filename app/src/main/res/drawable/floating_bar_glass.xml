<?xml version="1.0" encoding="utf-8"?>
<!-- Floating Bar Glass Background - iOS Style -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main glass surface -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F2FFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Inner highlight (top light reflection) -->
    <item android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Subtle border for glass effect -->
    <item>
        <shape android:shape="rectangle">
            <stroke 
                android:width="0.5dp" 
                android:color="#30FFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</layer-list>
